class MasterTableControllerTest {

    private MasterTableService service;
    private JwtToUserContextConverter jwtToUserContextConverter;
    private MockMvc mockMvc;
    private ObjectMapper objectMapper;

    @BeforeEach
    void setUp() {
        service = Mockito.mock(MasterTableService.class);
        jwtToUserContextConverter = Mockito.mock(JwtToUserContextConverter.class);

        MasterTableController controller = new MasterTableController(service, jwtToUserContextConverter);

        mockMvc = MockMvcBuilders.standaloneSetup(controller).build();
        objectMapper = new ObjectMapper();
    }

    private UserContext user() {
        UserContext uc = Mockito.mock(UserContext.class);
        Mockito.when(uc.getUsername()).thenReturn("testUser");
        return uc;
    }

    // ---------- TEST: retriveManagedTables ----------
    @Test
    void retriveManagedTables_ok_defaultSection() throws Exception {
        Page<MasterTableResponseDTO> page = Mockito.mock(Page.class);
        Pageable pageable = PageRequest.of(0, 1);
        String authorization = "auth";

        Mockito.when(jwtToUserContextConverter.convert(authorization)).thenReturn(user());
        Mockito.when(service.retriveManagedTables(TableSectionEnum.COMMON, pageable)).thenReturn(page);
        Mockito.when(page.getSort()).thenReturn(Sort.unsorted());

        mockMvc.perform(post("/api/admin/COMMON/tables")
                        .param("pageNumber", "0")
                        .param("pageSize", "1")
                        .header(HttpHeaders.AUTHORIZATION, authorization))
                .andExpect(status().isOk());

        Mockito.verify(service).retriveManagedTables(TableSectionEnum.COMMON, pageable);
    }

    @Test
    void retriveManagedTables_ok_otherSection() throws Exception {
        Page<MasterTableResponseDTO> page = Mockito.mock(Page.class);
        Pageable pageable = PageRequest.of(0, 1);
        String authorization = "auth";

        Mockito.when(jwtToUserContextConverter.convert(authorization)).thenReturn(user());
        Mockito.when(service.retriveManagedTables(TableSectionEnum.CREDIT, pageable)).thenReturn(page);
        Mockito.when(page.getSort()).thenReturn(Sort.unsorted());

        mockMvc.perform(post("/api/admin/CREDIT/tables")
                        .param("pageNumber", "0")
                        .param("pageSize", "1")
                        .header(HttpHeaders.AUTHORIZATION, authorization))
                .andExpect(status().isOk());

        Mockito.verify(service).retriveManagedTables(TableSectionEnum.CREDIT, pageable);
    }

    // ---------- TEST: retrieveTable ----------
    @Test
    void retrieveTable_ok() throws Exception {
        Page<Map<String, Object>> page = Mockito.mock(Page.class);
        Pageable pageable = PageRequest.of(0, 1);
        String authorization = "auth";

        Mockito.when(jwtToUserContextConverter.convert(authorization)).thenReturn(user());
        Mockito.when(service.loadTable("T_TEST", pageable)).thenReturn(page);
        Mockito.when(page.getSort()).thenReturn(Sort.unsorted());

        mockMvc.perform(post("/api/admin/tables/T_TEST/records")
                        .param("pageNumber", "0")
                        .param("pageSize", "1")
                        .header(HttpHeaders.AUTHORIZATION, authorization))
                .andExpect(status().isOk());

        Mockito.verify(service).loadTable("T_TEST", pageable);
    }

    // ---------- TEST: saveTable ----------
    @Test
    void saveTable_ok() throws Exception {
        String authorization = "auth";
        BaseTableRequestDTO body = new BaseTableRequestDTO();
        body.setMandantID("123");

        Mockito.when(jwtToUserContextConverter.convert(authorization)).thenReturn(user());

        mockMvc.perform(put("/api/admin/tables/T_TEST/save")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(body))
                        .header(HttpHeaders.AUTHORIZATION, authorization))
                .andExpect(status().isOk());

        Mockito.verify(service).saveTable(eq("T_TEST"), eq(body), any(UserContext.class));
    }

    @Test
    void saveTable_missingMandantID_shouldFail() throws Exception {
        String authorization = "auth";
        BaseTableRequestDTO body = new BaseTableRequestDTO(); // mandantID = null

        Mockito.when(jwtToUserContextConverter.convert(authorization)).thenReturn(user());

        mockMvc.perform(put("/api/admin/tables/T_TEST/save")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(objectMapper.writeValueAsString(body))
                        .header(HttpHeaders.AUTHORIZATION, authorization))
                .andExpect(status().is5xxServerError()); // AdminException lanciata
    }
}
