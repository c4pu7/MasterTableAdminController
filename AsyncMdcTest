import eu.unicredit.xframe.qrh.admin.rs.service.AsyncLoggingService;
import lombok.extern.slf4j.Slf4j;
import org.junit.jupiter.api.Test;
import org.slf4j.MDC;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.beans.factory.annotation.Qualifier;

@Slf4j
public class AsyncMdcTest extends BaseContextTest {

    @Autowired
    @Qualifier(value = AsyncLoggingService.SERVICE_NAME)
    private AsyncLoggingService asyncLoggingService;


    @Test
    void shouldBeAbleToPropagateTheMdcVariables() {
        MDC.put("pippo", "pluto");
        log.info("Main Thread ID: {}", Thread.currentThread().getId());
        asyncLoggingService.asyncTest();
    }
}
