
@RestController
@RequestMapping(ControllerConstants.ADMIN_API_CONTEXT)
@Slf4j
public class MasterTableController {

    private final MasterTableService service;
    private final JwtToUserContextConverter jwtToUserContextConverter;

    public MasterTableController(MasterTableService service,
                                 @Qualifier(JwtToUserContextConverter.SERVICE_NAME) JwtToUserContextConverter jwtToUserContextConverter) {
        this.service = service;
        this.jwtToUserContextConverter = jwtToUserContextConverter;
    }

    /**
     * retrive and display list of managed tables for a section
     * ex: Get api/admin/COMMON/tables
     */
    @PostMapping("/{section}/tables")
    @ApiResponses({
            @ApiResponse(code = 200, message = "OK", response = MasterTableResponseDTO.class),
            @ApiResponse(code = 400, message = "Bad request: one of the specified parameter has a wrong format or a parameter is missing"),
            @ApiResponse(code = 401, message = "Not authorized: the user is not authenticated"),
            @ApiResponse(code = 403, message = "Forbidden: the user is authenticated but do not have the authority to perform this action"),
            @ApiResponse(code = 417, message = "Expectation failed: there are no access rights available for this SECTIONS"),
            @ApiResponse(code = 500, message = "Generic error", response = ApiError.class)
    })
    public ResponseEntity<PageResponseDTO<MasterTableResponseDTO>> retriveManagedTables(@RequestParam(name = "section", required = false, defaultValue = "COMMON") TableSectionEnum section,
                                                                                        @RequestParam(defaultValue = "0") int pageNumber,
                                                                                        @RequestParam(defaultValue = "1") int pageSize,
                                                                                        @RequestHeader(org.springframework.http.HttpHeaders.AUTHORIZATION) String authorizationHeader) {
        //todo questo controllo potrebbe non servirmi se non necessaria autenticaizone
        UserContext userContext = jwtToUserContextConverter.convert(authorizationHeader);
        if (userContext == null) {
            throw new AdminException("Unable to validate user identity", Collections.singletonList("user-not-valid"));
        }
        Page<MasterTableResponseDTO> resultsPage;
        //pezzo per gestire section vuota, null o valore sbagliato
//        TableSectionEnum tableSectionEnum= (section == null || section.isBlank()) ? TableSectionEnum.COMMON : TableSectionEnum.valueOf(section.toUpperCase());
        resultsPage = service.retriveManagedTables(section, PageRequest.of(pageNumber, pageSize));
        return ResponseEntity.ok()
                .body(generatePaginationHttpForListResponse(resultsPage));
    }

    @PostMapping("/tables/{tableId}/records")
    @ApiResponses({
            @ApiResponse(code = 200, message = "OK", response = TableAttributesDTO.class),
            @ApiResponse(code = 400, message = "Bad request: one of the specified parameter has a wrong format or a parameter is missing"),
            @ApiResponse(code = 401, message = "Not authorized: the user is not authenticated"),
            @ApiResponse(code = 403, message = "Forbidden: the user is authenticated but do not have the authority to perform this action"),
            @ApiResponse(code = 500, message = "Generic error", response = ApiError.class)
    })
    public ResponseEntity<PageResponseDTO<Map<String, Object>>> retrieveTable(
            @PathVariable("tableId") String tableName,
            @RequestParam(defaultValue = "0") int pageNumber,
            @RequestParam(defaultValue = "1") int pageSize,
            @RequestHeader(HttpHeaders.AUTHORIZATION) String authorizationHeader
    ) {
        //todo questo controllo potrebbe non servirmi se non necessaria autenticaizone
        UserContext userContext = jwtToUserContextConverter.convert(authorizationHeader);
        if (userContext == null) {
            throw new AdminException("Unable to validate user identity", Collections.singletonList("user-not-valid"));
        }

        Page<Map<String, Object>> resultsPage =
                (Page<Map<String, Object>>) service.loadTable(
                        tableName,
                        PageRequest.of(pageNumber, pageSize)
                );

        return ResponseEntity.ok()
                .body(generatePaginationHttpForListResponse(resultsPage));
    }

    @PutMapping("/tables/{tableId}/save")
    @ApiResponses({
            @ApiResponse(code = 200, message = "OK: document successfully updated", response = String.class),
            @ApiResponse(code = 201, message = "OK: document created successfully", response = String.class),
            @ApiResponse(code = 400, message = "Bad request: one of the specified parameter has a wrong format or a parameter is missing"),
            @ApiResponse(code = 401, message = "Not authorized: the user is not authenticated"),
            @ApiResponse(code = 403, message = "Forbidden: the user is authenticated but do not have the authority to perform this action"),
            @ApiResponse(code = 416, message = "OK: document successfully updated with warnings", response = String.class),
            @ApiResponse(code = 500, message = "Generic error", response = ApiError.class)
    })
    public ResponseEntity<Void> saveTable(@PathVariable String tableId,
                                          @RequestBody BaseTableRequestDTO body,
                                          @RequestHeader(HttpHeaders.AUTHORIZATION) String authorizationHeader) {
        //todo questo controllo potrebbe non servirmi se non necessaria autenticaizone
        UserContext userContext = jwtToUserContextConverter.convert(authorizationHeader);
        if (userContext == null) {
            throw new AdminException("Unable to validate user identity", Collections.singletonList("user-not-valid"));
        }

        if (body.getMandantID() == null || body.getMandantID().isBlank()) {
            throw new AdminException("MandantID cannot be null or blank", Collections.singletonList("mandantID-not-null"));
        }

        log.info("User [{}] requested the save of document with ID: [{}]", userContext.getUsername(), body.getMandantID());
        service.saveTable(tableId, body, userContext);
        return ResponseEntity.ok().build();
    }
}
