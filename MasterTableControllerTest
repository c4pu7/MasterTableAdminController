@WebMvcTest(
        controllers = MasterTableController.class,
        excludeFilters = {
                @ComponentScan.Filter(type = FilterType.REGEX, pattern = "eu.unicredit.qrh.*"),
                @ComponentScan.Filter(type = FilterType.REGEX, pattern = "eu.unicredit.xframe.qrh.core.*")
        }
)
@AutoConfigureMockMvc(addFilters = false)
class MasterTableControllerTest {

    @Autowired
    private MockMvc mockMvc;

    @MockBean
    private MasterTableService service;

    @MockBean
    private JwtToUserContextConverter jwtToUserContextConverter;

    @Autowired
    private ObjectMapper mapper;

    private UserContext user() {
        return UserContext.builder()
                .username("admin")
                .build();
    }

    // =========================
    // RETRIEVE MANAGED TABLES
    // =========================

    @Test
    void retriveManagedTables_ok() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(user());

        Page<MasterTableResponseDTO> page = new PageImpl<>(
                List.of(new MasterTableResponseDTO()),
                PageRequest.of(0, 1),
                1
        );

        when(service.retriveManagedTables(any(), any())).thenReturn(page);

        mockMvc.perform(post("/api/admin/COMMON/tables")
                        .param("pageNumber", "0")
                        .param("pageSize", "1")
                        .header("Authorization", "token"))
                .andExpect(status().isOk());

        verify(service).retriveManagedTables(any(), any());
    }

    @Test
    void retriveManagedTables_userNull() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(null);

        mockMvc.perform(post("/api/admin/COMMON/tables")
                        .header("Authorization", "token"))
                .andExpect(status().is4xxClientError());

        verifyNoInteractions(service);
    }

    // =========================
    // RETRIEVE TABLE
    // =========================

    @Test
    void retrieveTable_ok() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(user());

        Page<String> page = new PageImpl<>(
                List.of("test"),
                PageRequest.of(0, 1),
                1
        );

        when(service.loadTable(any(), any())).thenReturn(page);

        mockMvc.perform(post("/api/admin/tables/T1/records")
                        .param("pageNumber", "0")
                        .param("pageSize", "1")
                        .header("Authorization", "token"))
                .andExpect(status().isOk());

        verify(service).loadTable(eq("T1"), any());
    }

    @Test
    void retrieveTable_userNull() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(null);

        mockMvc.perform(post("/api/admin/tables/T1/records")
                        .header("Authorization", "token"))
                .andExpect(status().is4xxClientError());

        verifyNoInteractions(service);
    }

    // =========================
    // SAVE TABLE
    // =========================

    @Test
    void saveTable_ok() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(user());

        BaseTableRequestDTO dto = new BaseTableRequestDTO() {
            @Override
            public String getConcreteTableName() {
                return "T1";
            }
        };
        dto.setMandantID("MAND");

        mockMvc.perform(put("/api/admin/tables/T1/save")
                        .header("Authorization", "token")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(mapper.writeValueAsString(dto)))
                .andExpect(status().isOk());

        verify(service).saveTable(eq("T1"), any(), any());
    }

    @Test
    void saveTable_mandantMissing() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(user());

        BaseTableRequestDTO dto = new BaseTableRequestDTO() {
            @Override
            public String getConcreteTableName() {
                return "T1";
            }
        };

        dto.setMandantID(null);

        mockMvc.perform(put("/api/admin/tables/T1/save")
                        .header("Authorization", "token")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(mapper.writeValueAsString(dto)))
                .andExpect(status().is4xxClientError());

        verifyNoInteractions(service);
    }

    @Test
    void saveTable_userNull() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(null);

        BaseTableRequestDTO dto = new BaseTableRequestDTO() {
            @Override
            public String getConcreteTableName() {
                return "T1";
            }
        };
        dto.setMandantID("MAND");

        mockMvc.perform(put("/api/admin/tables/T1/save")
                        .header("Authorization", "token")
                        .contentType(MediaType.APPLICATION_JSON)
                        .content(mapper.writeValueAsString(dto)))
                .andExpect(status().is4xxClientError());

        verifyNoInteractions(service);
    }

    // =========================
    // EXTRA (boost coverage)
    // =========================

    @Test
    void retrieveTable_serviceThrows() throws Exception {

        when(jwtToUserContextConverter.convert(any())).thenReturn(user());

        when(service.loadTable(any(), any()))
                .thenThrow(new RuntimeException("boom"));

        mockMvc.perform(post("/api/admin/tables/T1/records")
                        .header("Authorization", "token"))
                .andExpect(status().is5xxServerError());
    }
}
