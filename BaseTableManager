
/**
 * Manager generico che:
 * - usa un repository tipizzato per la tabella
 * - usa un mapper (iniettato) per DTO <-> Entity
 * - NON fa validazioni (scelta progettuale attuale)
 */
public abstract class BaseTableManager<
        E extends BaseTableRequestEntity,
        ID,
        DTO extends BaseTableRequestDTO> {

    protected final BaseTableRepository<E, ID> repository;

    protected BaseTableManager(BaseTableRepository<E, ID> repository) {
        this.repository = repository;
    }

    protected abstract DTO toDTO(E entity);
    protected abstract E toEntity(DTO dto);

    public Page<DTO> loadTable(Pageable pageable) {
        Page<E> page = repository.findAll(pageable);
        return new PageImpl<>(
                page.getContent().stream().map(this::toDTO).collect(Collectors.toList()),
                pageable,
                page.getTotalElements()
        );
    }

    public void saveTable(DTO dto, UserContext uc, LocalDateTime now) {
        E entity = toEntity(dto);
        entity.setUpdateUser(uc.getUsername());
        entity.setUpdateDate(now);
        repository.saveEntity(entity);
    }
}
